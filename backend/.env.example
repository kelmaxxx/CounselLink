PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=counselink
DB_PORT=3306
# Local MySQL: leave DB_SSL unset. Hosted MySQL (Aiven/Railway): set DB_SSL=true.
# DB_CA_PATH is optional — point it at the provider's CA cert (e.g. ./ca.pem) to
# fully verify the connection; omit it to connect encrypted-but-unverified.
DB_SSL=
DB_CA_PATH=
# Generate a real secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server refuses to start in production while this is a placeholder.
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins (no trailing slashes).
# Production example: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
NODE_ENV=development

# Email (Brevo HTTP API)
# We send through Brevo's API over HTTPS because Render blocks outbound SMTP
# ports. Create an API key under Brevo > SMTP & API > API Keys, and verify the
# EMAIL_FROM address under Brevo > Senders (single-sender verification — no
# domain required). EMAIL_FROM must exactly match a verified sender.
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM="CounselLink <your_verified_sender@gmail.com>"
